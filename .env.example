# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ─── App ─────────────────────────────────────────────────────────────────────
# When VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are set, the app reads/writes
# from Supabase. Without them it falls back to in-memory mock data.
VITE_APP_NAME=InventoPro
